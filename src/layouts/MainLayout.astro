---
import '../styles/global.css';

interface Props {
  title: string;
  noSidebar?: boolean;
}

const { title, noSidebar = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';

/* ── Lesson navigation ── */
const lessons = [
  { slug: 'spolecna-prace', title: '1 – Společná práce' },
  { slug: 'spolecna-prace-priklady', title: '2 – Příklady k procvičení' },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | Gymnázium – Studijní portál</title>
  </head>

  <body class="min-h-screen">
    <!-- ====== Top bar ====== -->
    <header class="bg-primary-700 text-white px-6 py-3 flex items-center justify-between shadow-md sticky top-0 z-40">
      <a href={base} class="text-lg font-bold tracking-wide hover:text-primary-200 transition-colors">
        🎓 Studijní portál
      </a>
      <div class="flex items-center gap-4">
        <span class="text-sm text-primary-300 hidden sm:inline">Gymnázium · Matematika</span>
      </div>
    </header>

    <div class="flex">
      <!-- ====== Sidebar (sticky) ====== -->
      <aside
        id="sidebar"
        class:list={[
          'w-64 shrink-0 bg-primary-50 border-r border-primary-200 sticky top-[52px] h-[calc(100vh-52px)] overflow-y-auto',
          noSidebar ? 'hidden' : 'hidden md:block'
        ]}
      >
        <nav class="p-4 space-y-1">
          <!-- ═══════════════════════════════════ -->
          <!-- TERCIE -->
          <!-- ═══════════════════════════════════ -->
          <h2 class="text-xs font-semibold uppercase tracking-wider text-primary-400 mb-3">
            📐 MATEMATIKA: Tercie
          </h2>
          
          <!-- Množina bodů daných vlastností - rozklikávací -->
          <details class="group" id="details-mnozina-bodu">
            <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-2 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors list-none">
              <span class="flex-1 nav-topic-link" data-href={`${base}docs/mnozina-bodu`}>Množina bodů daných vlastností</span>
              <svg class="w-4 h-4 transition-transform group-open:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            
            <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
              <div class="pt-2 pb-1">
                <span class="text-xs font-semibold uppercase tracking-wider text-primary-400 px-3">
                  📚 Lekce
                </span>
              </div>
              
              <a href={`${base}docs/mnozina-bodu#1-o-co-jde`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                1. O co jde?
              </a>
              <a href={`${base}docs/mnozina-bodu#2-kruznice`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                2. Kružnice
              </a>
              <a href={`${base}docs/mnozina-bodu#3-osa-usecky`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                3. Osa úsečky
              </a>
              <a href={`${base}docs/mnozina-bodu#4-osa-uhlu`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                4. Osa úhlu
              </a>
              <a href={`${base}docs/mnozina-bodu#5-rovnobezky`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                5. Rovnoběžky
              </a>
              <a href={`${base}docs/mnozina-bodu#rychly-test`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                🧠 Rychlý test
              </a>
              <a href={`${base}docs/mnozina-bodu#6-prehled`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                6. Přehled
              </a>
              <a href={`${base}docs/mnozina-bodu#7-priklady`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                7. Příklady
              </a>
              <a href={`${base}docs/mnozina-bodu#8-pozor`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                8. Na co si dát pozor
              </a>
              <a href={`${base}docs/mnozina-bodu#9-shrnuti`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                9. Shrnutí
              </a>
              <a href={`${base}docs/mnozina-bodu#10-over-si-znalosti`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                ✅ Ověř si znalosti
              </a>
              
              <div class="pt-3 pb-1">
                <span class="text-xs font-semibold uppercase tracking-wider text-primary-400 px-3">
                  🏠 Procvičování
                </span>
              </div>
              <a href={`${base}docs/mnozina-bodu-priklady`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                Příklady z praxe
              </a>
            </div>
          </details>
        </nav>
      </aside>

      <!-- ====== Main content ====== -->
      <main id="main-content" class:list={[
        'flex-1 p-6 md:p-10 w-full',
        noSidebar ? 'max-w-7xl mx-auto' : 'max-w-4xl mx-auto'
      ]}>
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>

    <!-- ====== Mobile menu toggle ====== -->
    <button
      id="menu-toggle"
      class:list={[
        'fixed bottom-4 right-4 md:hidden z-50 bg-primary-700 text-white p-3 rounded-full shadow-lg hover:bg-primary-600 transition-colors',
        noSidebar && 'hidden'
      ]}
      aria-label="Otevřít menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <script is:inline>
      // Mobile menu toggle
      const btn = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      btn?.addEventListener('click', () => {
        sidebar?.classList.toggle('hidden');
        sidebar?.classList.toggle('fixed');
        sidebar?.classList.toggle('inset-0');
        sidebar?.classList.toggle('z-40');
        sidebar?.classList.toggle('w-full');
      });

      // Auto-open details if we're on that page
      const currentPath = window.location.pathname;
      if (currentPath.includes('mnozina-bodu')) {
        const details = document.getElementById('details-mnozina-bodu');
        if (details) details.open = true;
      }

      // Topic link click: navigate AND open details
      document.querySelectorAll('.nav-topic-link').forEach(link => {
        link.style.cursor = 'pointer';
        link.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const details = link.closest('details');
          if (details) details.open = true;
          const href = link.getAttribute('data-href');
          if (href) window.location.href = href;
        });
      });

      // Arrow click: only toggle, don't navigate
      document.querySelectorAll('.toggle-arrow').forEach(arrow => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const details = arrow.closest('details');
          if (details) details.open = !details.open;
        });
      });

      // Sidebar links now work natively with anchor navigation
      // No custom scroll handling needed - browser handles it
    </script>
  </body>
</html>