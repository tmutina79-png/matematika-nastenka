---
import '../styles/global.css';

interface Props {
  title: string;
  noSidebar?: boolean;
}

const { title, noSidebar = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';

/* ── Lesson navigation ── */
const lessons = [
  { slug: 'spolecna-prace', title: '1 – Společná práce' },
  { slug: 'spolecna-prace-priklady', title: '2 – Příklady k procvičení' },
];
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | Gymnázium – Studijní portál</title>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- ====== Top bar ====== -->
    <header class="bg-primary-700 text-white px-6 py-3 flex items-center justify-between shadow-md sticky top-0 z-40">
      <a href={base} id="home-link" class="text-lg font-bold tracking-wide hover:text-primary-200 transition-colors"
         onclick="sessionStorage.removeItem('sidebar-details-state')">
        🎓 Studijní portál
      </a>
      <div class="flex items-center gap-4">
        <span class="text-sm text-primary-300 hidden sm:inline">Projekt NPI – Výukové materiály</span>
      </div>
    </header>

    <div class="flex flex-1">
      <!-- ====== Sidebar (sticky) ====== -->
      <aside
        id="sidebar"
        class:list={[
          'w-64 shrink-0 bg-primary-50 border-r border-primary-200 sticky top-[52px] h-[calc(100vh-52px)] overflow-y-auto',
          noSidebar ? 'hidden' : 'hidden md:block'
        ]}
      >
        <nav class="p-4 space-y-1">

          <!-- ═══════════════════════════════════════════ -->
          <!-- 📐 MATEMATIKA                              -->
          <!-- ═══════════════════════════════════════════ -->
          <details class="group/subject" id="details-matematika">
            <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-2 text-xs font-bold uppercase tracking-wider text-primary-700 hover:bg-primary-200 transition-colors list-none">
              <span>📐 Matematika</span>
              <svg class="w-4 h-4 transition-transform group-open/subject:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-300 space-y-1">

              <!-- ── 1. Výukový materiál ── -->
              <details class="group/class" id="details-mat-vm1">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>1. Výukový materiál</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">

                  <!-- Množina bodů daných vlastností -->
                  <details class="group/topic" id="details-mnozina-bodu">
                    <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors list-none">
                      <span class="flex-1 nav-topic-link" data-href={`${base}docs/mnozina-bodu`}>Množina bodů daných vlastností</span>
                      <svg class="w-3.5 h-3.5 transition-transform group-open/topic:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </summary>
                    <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-100 space-y-0.5">
                      <!-- Prezentace -->
                      <button id="open-prezentace" class="sidebar-link flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-semibold text-indigo-500 hover:bg-indigo-100 transition-colors w-full text-left cursor-pointer" data-src={`${base}prezentace/mnozina-bodu`}>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2" stroke-width="2"/><line x1="8" y1="21" x2="16" y2="21" stroke-width="2"/><line x1="12" y1="17" x2="12" y2="21" stroke-width="2"/></svg>
                        🎬 Prezentace
                      </button>
                      <!-- Procvičování -->
                      <details class="group/practice" id="details-procvicovani">
                        <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary-400 hover:bg-primary-100 transition-colors list-none">
                          <span>🏠 Příklady k procvičení</span>
                          <svg class="w-3 h-3 transition-transform group-open/practice:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                          </svg>
                        </summary>
                        <div class="ml-2 mt-1 space-y-0.5">
                          <a href={`${base}docs/mnozina-bodu-priklady`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                            Příklady z praxe
                          </a>
                          <a href={`${base}docs/mnozina-bodu-sada`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">
                            Sada příkladů
                          </a>
                        </div>
                      </details>
                      <!-- Lekce -->
                      <details class="group/lekce" id="details-lekce">
                        <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary-400 hover:bg-primary-100 transition-colors list-none">
                          <span>📚 Lekce</span>
                          <svg class="w-3 h-3 transition-transform group-open/lekce:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                          </svg>
                        </summary>
                        <div class="ml-2 mt-1 space-y-0.5">
                          <a href={`${base}docs/mnozina-bodu#1-o-co-jde`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">1. O co jde?</a>
                          <a href={`${base}docs/mnozina-bodu#2-kruznice`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">2. Kružnice</a>
                          <a href={`${base}docs/mnozina-bodu#3-osa-usecky`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">3. Osa úsečky</a>
                          <a href={`${base}docs/mnozina-bodu#4-osa-uhlu`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">4. Osa úhlu</a>
                          <a href={`${base}docs/mnozina-bodu#5-rovnobezky`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">5. Rovnoběžky</a>
                          <a href={`${base}docs/mnozina-bodu#rychly-test`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">🧠 Rychlý test</a>
                          <a href={`${base}docs/mnozina-bodu#6-prehled`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">6. Přehled</a>
                          <a href={`${base}docs/mnozina-bodu#7-priklady`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">7. Příklady</a>
                          <a href={`${base}docs/mnozina-bodu#8-pozor`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">8. Na co si dát pozor</a>
                          <a href={`${base}docs/mnozina-bodu#9-shrnuti`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">9. Shrnutí</a>
                          <a href={`${base}docs/mnozina-bodu#10-over-si-znalosti`} class="sidebar-link block rounded-md px-3 py-1 text-xs font-medium text-primary-600 hover:bg-primary-200 transition-colors">✅ Ověř si znalosti</a>
                        </div>
                      </details>
                    </div>
                  </details>

                  <!-- Úměrnost -->
                  <a href={`${base}docs/umernost`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors" hidden>
                    Přímá a nepřímá úměrnost
                  </a>
                </div>
              </details>

              <!-- ── 2. Výukový materiál ── -->
              <details class="group/class2" id="details-mat-vm2">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>2. Výukový materiál</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class2:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/mnozina-bodu-kruznice`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Množina bodů – Kružnice
                  </a>
                  <a href={`${base}docs/mnozina-bodu-kruznice-priklady`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    📐 Příklady – Kružnice
                  </a>
                </div>
              </details>

              <!-- ── 3. Výukový materiál ── -->
              <details class="group/class3" id="details-mat-vm3">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>3. Výukový materiál</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class3:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/mnozina-bodu-osa-usecky`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Množina bodů – Osa úsečky
                  </a>
                  <a href={`${base}docs/mnozina-bodu-osa-usecky-priklady`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    📐 Příklady – Osa úsečky
                  </a>
                </div>
              </details>

              <!-- ── 4. Výukový materiál ── -->
              <details class="group/class4" id="details-mat-vm4">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>4. Výukový materiál</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class4:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/mnozina-bodu-osa-uhlu`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Množina bodů – Osa úhlu
                  </a>
                  <a href={`${base}docs/mnozina-bodu-osa-uhlu-priklady`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    📐 Příklady – Osa úhlu
                  </a>
                </div>
              </details>

              <!-- ── 5. Výukový materiál ── -->
              <details class="group/class5" id="details-mat-vm5">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>5. Výukový materiál</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class5:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/mnozina-bodu-rovnobezky`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Množina bodů – Rovnoběžky
                  </a>
                  <a href={`${base}docs/mnozina-bodu-rovnobezky-priklady`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    📏 Příklady – Rovnoběžky
                  </a>
                </div>
              </details>

            </div>
          </details>
          <!-- ═══════════════════════════════════════════ -->
          <details class="group/subject2" id="details-informatika" hidden>
            <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-2 text-xs font-bold uppercase tracking-wider text-primary-700 hover:bg-primary-200 transition-colors list-none">
              <span>💻 Informatika</span>
              <svg class="w-4 h-4 transition-transform group-open/subject2:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-300 space-y-1">

              <!-- ── Ostatní ── -->
              <details class="group/class4" id="details-inf-ostatni">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>Ostatní</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class4:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/python-text`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Python – práce s textem
                  </a>
                </div>
              </details>

            </div>
          </details>

          <!-- ═══════════════════════════════════════════ -->
          <!-- 🔭 FYZIKA                                  -->
          <!-- ═══════════════════════════════════════════ -->
          <details class="group/subject3" id="details-fyzika" hidden>
            <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-2 text-xs font-bold uppercase tracking-wider text-primary-700 hover:bg-primary-200 transition-colors list-none">
              <span>🔭 Fyzika</span>
              <svg class="w-4 h-4 transition-transform group-open/subject3:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-300 space-y-1">

              <!-- ── Ostatní ── -->
              <details class="group/class5" id="details-fyz-ostatni">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>Ostatní</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class5:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/relativita`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Teorie relativity
                  </a>
                </div>
              </details>

            </div>
          </details>

          <!-- ═══════════════════════════════════════════ -->
          <!-- 📦 OSTATNÍ                                 -->
          <!-- ═══════════════════════════════════════════ -->
          <details class="group/subject4" id="details-ostatni" hidden>
            <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-2 text-xs font-bold uppercase tracking-wider text-primary-700 hover:bg-primary-200 transition-colors list-none">
              <span>📦 Ostatní</span>
              <svg class="w-4 h-4 transition-transform group-open/subject4:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-300 space-y-1">

              <!-- ── Tercie ── -->
              <details class="group/class6" id="details-ost-tercie">
                <summary class="flex items-center justify-between cursor-pointer rounded-md px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-primary-500 hover:bg-primary-100 transition-colors list-none">
                  <span>Tercie</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open/class6:rotate-180 toggle-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="ml-2 mt-1 pl-3 border-l-2 border-primary-200 space-y-0.5">
                  <a href={`${base}docs/karel-capek`} class="sidebar-link block rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-200 transition-colors">
                    Karel Čapek
                  </a>
                </div>
              </details>

            </div>
          </details>

        </nav>
      </aside>

      <!-- ====== Main content ====== -->
      <main id="main-content" class:list={[
        'flex-1 p-6 md:p-10 w-full',
        noSidebar ? 'max-w-7xl mx-auto' : 'max-w-4xl mx-auto'
      ]}>
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>

    <!-- ====== Prezentace Modal ====== -->
    <div id="prezentace-modal" class="fixed inset-0 z-[9999] hidden">
      <!-- backdrop -->
      <div id="prezentace-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
      <!-- modal container -->
      <div class="absolute inset-2 sm:inset-4 md:inset-6 flex flex-col bg-white rounded-2xl shadow-2xl overflow-hidden">
        <!-- header -->
        <div class="flex items-center justify-between px-4 py-2 bg-gradient-to-r from-indigo-600 to-purple-600 text-white">
          <span class="text-sm font-semibold">🎬 Prezentace – Množina bodů daných vlastností</span>
          <div class="flex items-center gap-2">
            <button id="prezentace-fullscreen" class="p-1.5 rounded-lg hover:bg-white/20 transition-colors" title="Celá obrazovka">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5v-4m0 4h-4m4 0l-5-5"/></svg>
            </button>
            <button id="prezentace-close" class="p-1.5 rounded-lg hover:bg-white/20 transition-colors" title="Zavřít">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
        </div>
        <!-- iframe -->
        <iframe id="prezentace-iframe" class="flex-1 w-full border-0" src="about:blank" allow="fullscreen"></iframe>
      </div>
    </div>

    <!-- ====== Footer ====== -->
    <footer class="bg-primary-50 border-t border-primary-200 py-4 text-center text-sm text-gray-500">
      <p>Interaktivní tabuli vytvořili: <strong class="text-gray-700">Ing. Tomáš Mutina</strong> a <strong class="text-gray-700">Mgr. Aleš Bajnar</strong></p>
    </footer>

    <!-- ====== Mobile sidebar backdrop ====== -->
    <div id="sidebar-backdrop" class="sidebar-backdrop"></div>

    <!-- ====== Mobile menu toggle ====== -->
    <button
      id="menu-toggle"
      class:list={[
        'fixed bottom-4 right-4 md:hidden z-50 bg-primary-700 text-white p-3 rounded-full shadow-lg hover:bg-primary-600 transition-colors',
        noSidebar && 'hidden'
      ]}
      aria-label="Otevřít menu"
    >
      <!-- Hamburger icon -->
      <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close icon (hidden by default) -->
      <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <script is:inline>
      // Mobile menu toggle
      const btn = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      const iconOpen = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');
      let menuOpen = false;

      function toggleMenu() {
        menuOpen = !menuOpen;
        if (menuOpen) {
          sidebar?.classList.remove('hidden');
          sidebar?.classList.add('sidebar-open');
          backdrop?.classList.add('active');
          iconOpen?.classList.add('hidden');
          iconClose?.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        } else {
          sidebar?.classList.add('hidden');
          sidebar?.classList.remove('sidebar-open');
          backdrop?.classList.remove('active');
          iconOpen?.classList.remove('hidden');
          iconClose?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }

      btn?.addEventListener('click', toggleMenu);
      backdrop?.addEventListener('click', toggleMenu);

      // ── Persist open/close state of sidebar details across navigations ──
      const STORAGE_KEY = 'sidebar-details-state';

      function saveDetailsState() {
        const state = {};
        document.querySelectorAll('#sidebar details[id]').forEach(d => {
          state[d.id] = d.open;
        });
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      }

      function restoreDetailsState() {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return;
        try {
          const state = JSON.parse(raw);
          Object.entries(state).forEach(([id, isOpen]) => {
            const el = document.getElementById(id);
            if (el) el.open = isOpen;
          });
        } catch (_) {}
      }

      // Auto-open ancestor details for the current page ONLY if no saved state
      const hasSavedState = !!sessionStorage.getItem(STORAGE_KEY);
      if (!hasSavedState) {
        // Close everything first
        document.querySelectorAll('#sidebar details[id]').forEach(d => { d.open = false; });
        const currentPath = window.location.pathname;
        // Find the sidebar link that matches current page and open all parent <details>
        document.querySelectorAll('#sidebar a.sidebar-link').forEach(link => {
          const href = link.getAttribute('href');
          if (href && currentPath.includes(href.split('#')[0].replace(/\/$/, '').split('/').pop())) {
            let el = link.closest('details');
            while (el) {
              el.open = true;
              el = el.parentElement?.closest('details');
            }
          }
        });
        // Also check nav-topic-link spans
        document.querySelectorAll('#sidebar .nav-topic-link').forEach(link => {
          const href = link.getAttribute('data-href');
          if (href && currentPath.includes(href.split('#')[0].replace(/\/$/, '').split('/').pop())) {
            let el = link.closest('details');
            while (el) {
              el.open = true;
              el = el.parentElement?.closest('details');
            }
          }
        });
      }

      // Restore sub-section state from sessionStorage (overrides defaults)
      restoreDetailsState();

      // Listen for toggle events on all sidebar details → save state
      document.querySelectorAll('#sidebar details[id]').forEach(d => {
        d.addEventListener('toggle', () => saveDetailsState());
      });

      // Topic link click: navigate AND open topic details (sub-sections stay as they are)
      document.querySelectorAll('.nav-topic-link').forEach(link => {
        link.style.cursor = 'pointer';
        link.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const details = link.closest('details');
          if (details) details.open = true;
          saveDetailsState();
          const href = link.getAttribute('data-href');
          if (href) window.location.href = href;
        });
      });

      // Arrow click: only toggle, don't navigate
      document.querySelectorAll('.toggle-arrow').forEach(arrow => {
        arrow.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          const details = arrow.closest('details');
          if (details) {
            details.open = !details.open;
            saveDetailsState();
          }
        });
      });

      // Sidebar links now work natively with anchor navigation
      // No custom scroll handling needed - browser handles it

      // ── Prezentace modal ──
      const prezModal = document.getElementById('prezentace-modal');
      const prezIframe = document.getElementById('prezentace-iframe');
      const prezOpen = document.getElementById('open-prezentace');
      const prezClose = document.getElementById('prezentace-close');
      const prezBackdrop = document.getElementById('prezentace-backdrop');
      const prezFullscreen = document.getElementById('prezentace-fullscreen');

      function openPrezentace() {
        const src = prezOpen?.getAttribute('data-src');
        if (prezIframe && src) prezIframe.src = src;
        prezModal?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closePrezentace() {
        prezModal?.classList.add('hidden');
        if (prezIframe) prezIframe.src = 'about:blank';
        document.body.style.overflow = '';
      }

      prezOpen?.addEventListener('click', openPrezentace);
      prezClose?.addEventListener('click', closePrezentace);
      prezBackdrop?.addEventListener('click', closePrezentace);

      prezFullscreen?.addEventListener('click', () => {
        const container = prezModal?.querySelector('div:nth-child(2)');
        if (container?.requestFullscreen) container.requestFullscreen();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !prezModal?.classList.contains('hidden')) {
          closePrezentace();
        }
      });
    </script>
  </body>
</html>