---
import MainLayout from '../layouts/MainLayout.astro';
import QRCode from '../components/QRCode.svelte';

const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : baseUrl + '/';
---

<MainLayout title="Materiály">
  <div class="flex items-start justify-between gap-4 mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Vítej na Studijním portálu 🎓</h1>
    <div class="shrink-0 flex flex-col items-center homepage-qr">
      <QRCode client:load url="https://tmutina79-png.github.io/matematika-nastenka/" title="QR kód portálu" />
      <span class="text-[10px] text-gray-400 mt-1">📱 Naskenuj a otevři na tabletu nebo mobilu</span>
    </div>
  </div>

  <section class="mb-8">
    <h2 class="text-lg font-semibold text-primary-700 mb-4">📐 MATEMATIKA: Množina bodů daných vlastností</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- VM 1 -->
      <a href={`${base}docs/mnozina-bodu`} data-sidebar="details-mat-vm1" class="vm-card group relative block rounded-xl border border-primary-200 bg-white p-4 pb-7 shadow-sm hover:shadow-md hover:border-primary-400 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold">1</span>
          <span class="text-sm font-bold text-primary-700 group-hover:text-primary-900 transition-colors">Množina bodů – přehled</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">Úvod do množin bodů daných vlastností – kružnice, osa úsečky, osa úhlu, rovnoběžky.</p>
        <span class="absolute bottom-1.5 right-2.5 text-[10px] font-semibold text-primary-400 opacity-70">1. Výukový materiál</span>
      </a>

      <!-- VM 2 -->
      <a href={`${base}docs/mnozina-bodu-kruznice`} data-sidebar="details-mat-vm2" class="vm-card group relative block rounded-xl border border-primary-200 bg-white p-4 pb-7 shadow-sm hover:shadow-md hover:border-primary-400 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold">2</span>
          <span class="text-sm font-bold text-primary-700 group-hover:text-primary-900 transition-colors">Kružnice</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">Kružnice jako množina bodů, pojmy, vlastnosti, konstrukce a příklady.</p>
        <span class="absolute bottom-1.5 right-2.5 text-[10px] font-semibold text-primary-400 opacity-70">2. Výukový materiál</span>
      </a>

      <!-- VM 3 -->
      <a href={`${base}docs/mnozina-bodu-osa-usecky`} data-sidebar="details-mat-vm3" class="vm-card group relative block rounded-xl border border-primary-200 bg-white p-4 pb-7 shadow-sm hover:shadow-md hover:border-primary-400 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold">3</span>
          <span class="text-sm font-bold text-primary-700 group-hover:text-primary-900 transition-colors">Osa úsečky</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">Osa úsečky – definice, vlastnosti, konstrukce a praktické příklady.</p>
        <span class="absolute bottom-1.5 right-2.5 text-[10px] font-semibold text-primary-400 opacity-70">3. Výukový materiál</span>
      </a>

      <!-- VM 4 -->
      <a href={`${base}docs/mnozina-bodu-osa-uhlu`} data-sidebar="details-mat-vm4" class="vm-card group relative block rounded-xl border border-primary-200 bg-white p-4 pb-7 shadow-sm hover:shadow-md hover:border-primary-400 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold">4</span>
          <span class="text-sm font-bold text-primary-700 group-hover:text-primary-900 transition-colors">Osa úhlu</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">Osa úhlu – definice, vlastnosti, konstrukce a praktické příklady.</p>
        <span class="absolute bottom-1.5 right-2.5 text-[10px] font-semibold text-primary-400 opacity-70">4. Výukový materiál</span>
      </a>

      <!-- VM 5 -->
      <a href={`${base}docs/mnozina-bodu-rovnobezky`} data-sidebar="details-mat-vm5" class="vm-card group relative block rounded-xl border border-primary-200 bg-white p-4 pb-7 shadow-sm hover:shadow-md hover:border-primary-400 transition-all">
        <div class="flex items-center gap-2 mb-2">
          <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-100 text-primary-700 text-xs font-bold">5</span>
          <span class="text-sm font-bold text-primary-700 group-hover:text-primary-900 transition-colors">Rovnoběžky</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed">Rovnoběžky s přímkou – definice, vlastnosti, konstrukce a praktické příklady.</p>
        <span class="absolute bottom-1.5 right-2.5 text-[10px] font-semibold text-primary-400 opacity-70">5. Výukový materiál</span>
      </a>

    </div>
  </section>

  <!-- Oddělovací čára -->
  <hr class="border-t border-gray-300 my-8" />

  <!-- Co portál nabízí -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold text-primary-700 mb-4">💡 Co všechno ti tato nástěnka žáka nabízí?</h2>

    <div class="bg-white rounded-xl border border-primary-100 shadow-sm p-6 space-y-3 text-sm text-gray-700 leading-relaxed">

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">📚</span>
        <p><strong>Celá látka na jednom místě</strong> – můžeš si projít všechna témata najednou, nebo postupně po jednom, vlastním tempem.</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">🖥️</span>
        <p><strong>Prezentace k hodině</strong> – ke každé lekci je připravena prezentace, která bude využita přímo ve výuce.</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">📝</span>
        <p><strong>Příklady dle obtížnosti</strong> – v každé lekci najdeš příklady seřazené podle složitosti, včetně postupného vysvětlení jednotlivých kroků řešení.</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">✅</span>
        <p><strong>Kontrolní kvízy k učivu</strong> – porozumění teorii a pojmům si ověříš kvízem, který je součástí každé lekce. Pro splnění potřebuješ alespoň 80 %, takže tipování není úplně cajk 😉</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">🧮</span>
        <p><strong>Kvízy s příklady</strong> – na závěr tě čeká kvíz s praktickými příklady, který prověří, zda látku dokážeš skutečně použít. I tady platí hranice 80 % – bez učení to nepůjde 🙂</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">📱</span>
        <p><strong>QR kód pro mobilní zobrazení</strong> – pomocí QR kódu si můžeš učivo pohodlně zobrazit na tabletu nebo telefonu.</p>
      </div>

      <div class="flex items-start gap-3">
        <span class="text-primary-500 mt-0.5">🖨️</span>
        <p><strong>Příklady k tisku (PDF)</strong> – příklady si můžeš vygenerovat do PDF, vytisknout a řešit ručně na papíře. Správnost postupu si pak průběžně ověříš na interaktivní tabuli.</p>
      </div>

    </div>
  </section>

  <script is:inline>
    // Na homepage: otevři jen Matematika, všechny VM zavřené
    (function() {
      const state = {};
      document.querySelectorAll('#sidebar details[id]').forEach(d => {
        state[d.id] = false;
      });
      state['details-matematika'] = true;
      sessionStorage.setItem('sidebar-details-state', JSON.stringify(state));
      // Ihned aplikuj na sidebar
      document.querySelectorAll('#sidebar details[id]').forEach(d => {
        d.open = !!state[d.id];
      });
    })();

    // Po kliknutí na kartu VM: otevři JEN Matematiku + kliknutý VM, ostatní zavřít
    document.querySelectorAll('.vm-card').forEach(card => {
      card.addEventListener('click', () => {
        const sidebarId = card.getAttribute('data-sidebar');
        if (!sidebarId) return;
        const state = {};
        document.querySelectorAll('#sidebar details[id]').forEach(d => {
          state[d.id] = false;
        });
        state['details-matematika'] = true;
        state[sidebarId] = true;
        sessionStorage.setItem('sidebar-details-state', JSON.stringify(state));
      });
    });
  </script>

  <style>
    .homepage-qr :global(.qr-btn) {
      width: 110px !important;
      height: 110px !important;
      border-radius: 12px !important;
    }
    .homepage-qr :global(.qr-small) {
      width: 100px !important;
      height: 100px !important;
    }
  </style>
</MainLayout>
